[Unit]
Description=Mini R56 OBD API Server
After=network.target

[Service]
Type=simple
User=lola
WorkingDirectory=/home/lola/mini_obd/app/api
ExecStart=/home/lola/obd_env/bin/uvicorn main:app --host 0.0.0.0 --port 8080 --log-level info
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
